# ═══════════════════════════════════════════════
# .gitignore — 告诉 git 哪些文件不要追踪、不要提交
# ═══════════════════════════════════════════════

# ── 依赖目录（几千个包，提交上去仓库会巨大且无意义）──
node_modules/

# ── 构建产物（每次 build 自动生成的，不需要保存）──
dist/
.astro/
site/dist/
site/.astro/

# ── 环境与密钥文件（⚠️ 最重要！绝不能提交）──
.env
.env.*
!.env.example
proxy/.env
proxy/.env.*
!proxy/.env.example

# ── 运行数据（留言板消息等运行时产生的数据）──
proxy/data/

# ── 日志与临时文件 ──
*.log
npm-debug.log*
*.tmp

# ── 操作系统垃圾文件 ──
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# ── IDE / 编辑器配置（每个人本地不同，不共享）──
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── 测试覆盖率报告 ──
coverage/

# ── 审计报告（太大且随时可重新生成）──
RC-AUDIT-REPORT*.md
