# 复制本文件为 .env 并填入真实值。.env 切勿提交到仓库 / 切勿暴露给前端。
# FastGPT API 基地址（你给的）
FASTGPT_BASE_URL=https://ai-china.itinfolab.cn/api

# FastGPT API Key —— 在此填入；建议先在 FastGPT 重置一个新 Key（旧的已在聊天里明文出现过）
FASTGPT_API_KEY=your-api-key-here

# 代理监听端口
PORT=8787

# 允许的前端来源：开发可用 *，上线后改成你的主页域名，例如 https://you.example.com
ALLOW_ORIGIN=*

# 单次 /api/chat 请求体大小限制（字节），默认 64KB
MAX_BODY_BYTES=65536

# 留言板存储文件路径（公共留言持久化，Req 17.4 / 20.3 / 20.4）。
# 本地运行默认 ./data/messages.json；docker-compose 部署时由 compose 注入
# MESSAGES_FILE=/app/data/messages.json 并挂载可写卷持久化，无需在此设置。
# MESSAGES_FILE=./data/messages.json

# 管理员密钥 —— 用于留言板管理面板（删除任意留言 / 清空全部）。
# 前端留言板底部「管理」按钮需输入此密钥才能进入管理模式。
# 留空 / 未设置则管理端点返回 503，管理功能不可用。
# ADMIN_KEY=your-secret-key-here
